    "@webgpu/types": "^0.1.69",
    "eslint": "^10.1.0",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^26.1.0",
    "puppeteer": "^24.40.0",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "vitest": "^3.2.4"
  },
  "license": "MIT"
